# StockPlanBackend environment template
# Copy to .env.development (local) or .env.production (server).
# Real secrets belong in gitignored env files or CI/CD secrets — never commit them.

LOG_LEVEL=debug

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=stockplan_dev
DATABASE_USERNAME=stockplan_user
DATABASE_PASSWORD=stockplan_password

# Auth (JWT)
JWT_SECRET=change-me-dev-use-32-plus-random-chars-in-production
JWT_EXPIRES_IN_SECONDS=604800
JWT_REFRESH_EXPIRES_IN_SECONDS=2592000

# Billing / trial access
# New accounts start on a temporary trial for this many days, then fall back to free.
AUTH_DEFAULT_TRIAL_DAYS=7
# Comma-separated email overrides that should resolve as permanent Pro while listed.
BILLING_PREMIUM_EMAILS=
# Local/test escape hatch only. Keep false in normal development and production.
BYPASS_BILLING=false
# RevenueCat server-side keys. Never expose these in StockPlanWeb or mobile clients.
REVENUECAT_API_KEY=
REVENUECAT_PROJECT_ID=
REVENUECAT_API_V2_KEY=
REVENUECAT_WEBHOOK_SECRET=
REVENUECAT_HMAC_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
# OAUTH_GOOGLE_CLIENT_ID is the iOS client (custom-scheme redirect, no secret) used by
# the native app. iOS-type clients CANNOT register https redirect URIs.
OAUTH_GOOGLE_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
# OAUTH_GOOGLE_CLIENT_SECRET only applies to a confidential/web client (optional here).
OAUTH_GOOGLE_CLIENT_SECRET=
# Browser (StockPlanWeb) sign-in needs a separate "Web application" client with a secret.
# Register https redirect URIs (e.g. https://www.norviq.org/auth/oauth/google/callback)
# on THIS client. Backend picks it automatically for http(s) redirect URIs.
OAUTH_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
OAUTH_GOOGLE_WEB_CLIENT_SECRET=your-web-client-secret

# Apple Sign In — https://developer.apple.com/account/resources/identifiers/list/serviceId
# Services ID (not App ID bundle) with Sign in with Apple enabled.
OAUTH_APPLE_CLIENT_ID=your.services.id
OAUTH_APPLE_TEAM_ID=your-team-id
OAUTH_APPLE_KEY_ID=your-sign-in-with-apple-key-id
# PEM from downloaded .p8 — use \n between lines in a single quoted string
OAUTH_APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Optional: X OAuth
OAUTH_X_CLIENT_ID=
OAUTH_X_CLIENT_SECRET=
OAUTH_X_SCOPES=tweet.read users.read offline.access

# Comma-separated exact redirect URIs (required in production).
# Include iOS, web local, web prod, Google iOS scheme, and Apple HTTPS bridge.
OAUTH_ALLOWED_REDIRECT_URIS=norviqa://oauth/callback,norviqa://oauth/broker-callback,http://localhost:6969/auth/oauth/google/callback,http://localhost:6969/auth/oauth/apple/callback,http://localhost:6969/settings/integrations/ibkr/callback,http://localhost:7000/auth/oauth/google/callback,http://localhost:7000/auth/oauth/apple/callback,http://localhost:7000/settings/integrations/ibkr/callback,com.googleusercontent.apps.YOUR_PREFIX:/oauth2redirect

# Optional: iOS custom scheme for OAuth bridge (default norviqa)
OAUTH_APP_CALLBACK_SCHEME=norviqa

# IBKR broker connect. Leave mode as gateway for Client Portal Gateway setups.
# Set IBKR_CONNECT_MODE=oauth2 and fill the OAuth values after IBKR Web API approval.
IBKR_CONNECT_MODE=gateway
IBKR_OAUTH_CLIENT_ID=
IBKR_OAUTH_KEY_ID=
IBKR_OAUTH_PRIVATE_KEY_PEM=
IBKR_OAUTH_AUTHORIZATION_URL=
IBKR_OAUTH_TOKEN_URL=
IBKR_OAUTH_API_BASE_URL=
IBKR_OAUTH_SCOPE=

# WebAuthn / Passkeys (optional — login disabled when unset)
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Norviq
WEBAUTHN_ORIGINS=http://localhost:6969,http://localhost:7000

# Redis (optional locally)
REDIS_URL=redis://localhost:6379

# Observability (OpenTelemetry + Grafana stack — see docs/Observability.md)
# Enable traces locally only when docker-compose.observability.yml is running.
OBS_TRACES_ENABLED=false
OBS_SERVICE_NAME=StockPlanBackend
OBS_ENVIRONMENT=development
OBS_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=StockPlanBackend
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=development
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
LOG_FORMAT=text

# Grafana (used by docker-compose.observability.yml overlay)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_SMTP_ENABLED=false
GRAFANA_ALERT_EMAIL_TO=
GRAFANA_ALERT_EMAIL_FROM=
GRAFANA_SMTP_HOST=
GRAFANA_SMTP_USER=
GRAFANA_SMTP_PASSWORD=
GRAFANA_SLACK_WEBHOOK_URL=

# Sentry (optional — leave empty for local dev)
# DSN is used by SentryReporter on 5xx errors and by web/iOS SDKs.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.2
# OTel Collector → Sentry OTLP (DE region example — match your Sentry project).
# Set SENTRY_DSN first, then run: python3 scripts/sync-sentry-otlp-env.py .env.production
# SENTRY_OTLP_TRACES_ENDPOINT=https://o4510766840872960.ingest.de.sentry.io/api/4511577338282064/integration/otlp/v1/traces
# SENTRY_OTLP_LOGS_ENDPOINT=https://o4510766840872960.ingest.de.sentry.io/api/4511577338282064/integration/otlp/v1/logs
# SENTRY_OTLP_AUTH_HEADER=sentry sentry_key=your_public_key

# Hermes finance insights (self-hosted agent, reached over Tailscale only).
# Leave HERMES_BASE_URL empty to disable the insights sync entirely.
# Use the VPS tailnet IP (tailscale ip -4 on the VPS); MagicDNS names do not
# resolve inside Docker containers.
HERMES_BASE_URL=
HERMES_API_TOKEN=
HERMES_SYNC_INTERVAL_SECONDS=900
HERMES_TRACKED_TICKERS=AMD,NVDA,AAPL
# Comma-separated emails allowed to POST /v1/insights/sync (force an immediate
# Hermes pull). Empty = the endpoint is disabled for everyone (fail-closed).
INSIGHTS_ADMIN_EMAILS=

# Macro / inflation data (Nowflation parity, /v1/macro/*).
# FRED is the keystone US provider — get a free key at
# https://fred.stlouisfed.org/docs/api/api_key.html. Without it the US stays on
# stub data; Eurostat (PT/EA) and IBGE (BR) need no key.
MACRO_ENABLED=true
FRED_API_KEY=
# Nowflation.com enrichment (daily US gauge layered over official FRED data).
# The site is a JS SPA: discover the open-data JSON URL via the browser
# network tab and set both values. Empty = enrichment disabled (official-only).
NOWFLATION_BASE_URL=
NOWFLATION_SNAPSHOT_PATH=
# Job tick + per-country refresh cadences (seconds).
MACRO_REFRESH_INTERVAL_SECONDS=3600
MACRO_US_REFRESH_SECONDS=21600
MACRO_INTL_REFRESH_SECONDS=86400
# Serve legacy stub data (marked source="stub") when no real data is available.
# Flip to false once live providers are verified in production.
MACRO_ALLOW_STUB_FALLBACK=true
# Hard-disabled enrichment stubs (no public API; scraping violates ToS).
MACRO_ENRICHMENT_SEEKING_ALPHA_ENABLED=false
MACRO_ENRICHMENT_INVESTING_ENABLED=false

# --- Scenario planning ---
# Keep disabled until migrations, market-history backfill, and worker capacity
# have been verified. Scenario API routes fail closed while this is false.
SCENARIO_PLANNING_ENABLED=false
# PostgreSQL-backed simulation worker polling cadence and per-replica CPU bound.
SCENARIO_WORKER_INTERVAL_SECONDS=2
SCENARIO_WORKER_MAX_CONCURRENT=2
# Incremental market-history refresh cadence (default: daily).
SCENARIO_HISTORY_REFRESH_SECONDS=86400

# --- Receipts ---
# Receipt OCR provider for POST /v1/receipts/ocr. "disabled" (default) turns off
# photo OCR; structured fiscal-QR parsing (/v1/receipts/parse-qr) always works.
RECEIPT_OCR_PROVIDER=disabled

# --- Bank sync (Plaid, US) ---
# Read-only transactions access. Leave unset to disable US bank sync.
PLAID_CLIENT_ID=
PLAID_SECRET=
# sandbox | development | production
PLAID_ENV=sandbox
# Webhook URL Plaid calls on new transactions (optional in sandbox).
PLAID_WEBHOOK_URL=
# Shared secret for verifying inbound Plaid webhooks (X-Plaid-Webhook-Secret).
PLAID_WEBHOOK_SECRET=
# Reconcile interval (seconds) for the missed-webhook backstop. Default 21600 (6h).
BANK_SYNC_INTERVAL=21600

# --- Tax projections and reports ---
# Comma-separated jurisdiction packs that have completed professional review.
# Keep preview-only packs absent; US is the only validated foundation by default.
TAX_VALIDATED_JURISDICTIONS=US
# Durable report output directory. Production should mount persistent storage here.
TAX_REPORT_STORAGE_PATH=./.tax-reports
# Queue polling cadence and expired-report cleanup cadence.
TAX_REPORT_GENERATION_POLL_SECONDS=10
TAX_REPORT_CLEANUP_INTERVAL_SECONDS=3600

# --- AI assistant and proactive financial tips ---
# openai | openrouter | custom. OpenRouter provides normalized access to
# Claude, Gemini, DeepSeek, Qwen, and other providers through one contract.
AI_PROVIDER=openai
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
AI_MAX_TOKENS=700
# Direct OpenAI compatibility (kept for existing deployments).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.6-terra
# OpenRouter mode. Prefer model snapshots/slugs reviewed for tool calling.
OPENROUTER_API_KEY=
# Per-workload overrides. OpenRouter examples:
# anthropic/claude-sonnet-4.6, google/gemini-3.5-flash,
# deepseek/deepseek-v4-flash, or a reviewed qwen/* model slug.
AI_CHAT_MODEL=
AI_TIPS_MODEL=

# --- Model Context Protocol service ---
# Generate one high-entropy value and use the same value for the API and MCP
# service. This authenticates private token-introspection requests.
MCP_INTROSPECTION_SECRET=
MCP_DOMAIN=mcp.norviq.org
MCP_IMAGE=ghcr.io/financeplanner/norviq-mcp:350d030459277a9dbd5a71549fe01aadc3feb684
