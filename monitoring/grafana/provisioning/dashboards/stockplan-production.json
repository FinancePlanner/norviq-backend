{
  "title": "StockPlan Production",
  "uid": "stockplan-production",
  "tags": ["stockplan", "production"],
  "refresh": "30s",
  "schemaVersion": 39,
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "editable": true,
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_milliseconds_count[5m])) by (http_route, http_method)",
          "legendFormat": "{{http_method}} {{http_route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_milliseconds_count{http_status_code=~\"5..\"}[5m])) by (http_route)",
          "legendFormat": "{{http_route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "HTTP P99 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_duration_milliseconds_bucket[5m])) by (le, http_route))",
          "legendFormat": "p99 {{http_route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "HTTP P50 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_duration_milliseconds_bucket[5m])) by (le, http_route))",
          "legendFormat": "p50 {{http_route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Host CPU Usage",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(system_cpu_time_seconds_total{state!=\"idle\"}[5m])",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Host Memory Usage",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "system_memory_usage_bytes",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "OTel Collector - Metrics Received",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(otelcol_receiver_accepted_metric_points[5m])",
          "legendFormat": "accepted",
          "refId": "A"
        },
        {
          "expr": "rate(otelcol_receiver_refused_metric_points[5m])",
          "legendFormat": "refused",
          "refId": "B"
        }
      ]
    },
    {
      "id": 8,
      "title": "OTel Collector - Traces Received",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(otelcol_receiver_accepted_spans[5m])",
          "legendFormat": "accepted",
          "refId": "A"
        },
        {
          "expr": "rate(otelcol_receiver_refused_spans[5m])",
          "legendFormat": "refused",
          "refId": "B"
        }
      ]
    },
    {
      "id": 9,
      "title": "Recent Traces",
      "type": "traces",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 10 },
      "datasource": { "type": "jaeger", "uid": "jaeger" },
      "targets": [
        {
          "queryType": "search",
          "service": "StockPlanBackend",
          "refId": "A"
        }
      ]
    }
  ]
}
